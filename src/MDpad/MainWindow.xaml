<Window
    x:Class="MDpad.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Window.Content>
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" Padding="4,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,0,8,0">
                <Button
                    x:Name="ModeToggleButton"
                    MinWidth="104"
                    Height="32"
                    Padding="12,0"
                    Click="ToggleMode_Click" />
                <Button
                    x:Name="BackButton"
                    Width="34"
                    Height="32"
                    Padding="0"
                    Click="Back_Click"
                    IsEnabled="False"
                    ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="15" />
                </Button>
                <Button
                    x:Name="ForwardButton"
                    Width="34"
                    Height="32"
                    Padding="0"
                    Click="Forward_Click"
                    IsEnabled="False"
                    ToolTipService.ToolTip="Forward">
                    <FontIcon Glyph="&#xE72A;" FontSize="15" />
                </Button>
            </StackPanel>

            <MenuBar Grid.Column="1" VerticalAlignment="Center">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="New" Click="New_Click" KeyboardAcceleratorTextOverride="Ctrl+N" />
                    <MenuFlyoutItem Text="Open..." Click="Open_Click" KeyboardAcceleratorTextOverride="Ctrl+O" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Save" Click="Save_Click" KeyboardAcceleratorTextOverride="Ctrl+S" />
                    <MenuFlyoutItem Text="Save As..." Click="SaveAs_Click" KeyboardAcceleratorTextOverride="Ctrl+Shift+S" />
                    <MenuFlyoutItem Text="Save HTML..." Click="SaveHtml_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="Exit_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Edit">
                    <MenuFlyoutItem x:Name="UndoItem" Text="Undo" Click="Undo_Click" KeyboardAcceleratorTextOverride="Ctrl+Z" />
                    <MenuFlyoutItem x:Name="RedoItem" Text="Redo" Click="Redo_Click" KeyboardAcceleratorTextOverride="Ctrl+Y" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="CutItem" Text="Cut" Click="Cut_Click" KeyboardAcceleratorTextOverride="Ctrl+X" />
                    <MenuFlyoutItem Text="Copy" Click="Copy_Click" KeyboardAcceleratorTextOverride="Ctrl+C" />
                    <MenuFlyoutItem x:Name="PasteItem" Text="Paste" Click="Paste_Click" KeyboardAcceleratorTextOverride="Ctrl+V" />
                    <MenuFlyoutItem x:Name="DeleteItem" Text="Delete" Click="Delete_Click" KeyboardAcceleratorTextOverride="Del" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Find" Click="Find_Click" KeyboardAcceleratorTextOverride="Ctrl+F" />
                    <MenuFlyoutItem x:Name="ReplaceItem" Text="Replace" Click="Replace_Click" KeyboardAcceleratorTextOverride="Ctrl+H" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Select All" Click="SelectAll_Click" KeyboardAcceleratorTextOverride="Ctrl+A" />
                </MenuBarItem>
                <MenuBarItem Title="View">
                    <MenuFlyoutItem x:Name="ViewModeItem" Text="Switch mode" Click="ToggleMode_Click" />
                    <ToggleMenuFlyoutItem x:Name="OpenFormattedByDefaultItem" Text="Open formatted by default" Click="OpenFormattedByDefault_Click" />
                    <ToggleMenuFlyoutItem x:Name="WordWrapItem" Text="Word wrap" Click="WordWrap_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Zoom In" Click="ZoomIn_Click" KeyboardAcceleratorTextOverride="Ctrl++" />
                    <MenuFlyoutItem Text="Zoom Out" Click="ZoomOut_Click" KeyboardAcceleratorTextOverride="Ctrl+-" />
                    <MenuFlyoutItem Text="Reset Zoom" Click="ResetZoom_Click" KeyboardAcceleratorTextOverride="Ctrl+0" />
                </MenuBarItem>
            </MenuBar>

            <Button
                x:Name="SettingsButton"
                Grid.Column="2"
                Width="34"
                Height="32"
                Padding="0"
                Click="Settings_Click"
                ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="15" />
            </Button>
        </Grid>

        <Border
            x:Name="FindPanel"
            Grid.Row="1"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,1"
            Padding="8"
            Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FindTextBox" Grid.Column="0" PlaceholderText="Find" />
                <TextBox x:Name="ReplaceTextBox" Grid.Column="1" PlaceholderText="Replace" />
                <Button Grid.Column="2" Content="Find Next" Click="FindNext_Click" />
                <Button x:Name="ReplaceButton" Grid.Column="3" Content="Replace" Click="ReplaceNext_Click" />
                <Button Grid.Column="5" Content="Close" Click="CloseFind_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <controls:WebView2
                x:Name="PreviewWebView"
                DefaultBackgroundColor="Transparent" />
            <TextBox
                x:Name="SourceTextBox"
                AcceptsReturn="True"
                Background="Transparent"
                BorderThickness="0"
                FontFamily="Cascadia Mono, Consolas"
                FontSize="14"
                Padding="16"
                TextChanged="SourceTextBox_TextChanged"
                TextWrapping="Wrap"
                Visibility="Collapsed" />
        </Grid>

        <Grid Grid.Row="3" Padding="10,0" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Text="Ready" />
            <TextBlock x:Name="ZoomTextBlock" Grid.Column="1" VerticalAlignment="Center" Text="100%" />
        </Grid>
    </Grid>
    </Window.Content>
</Window>
